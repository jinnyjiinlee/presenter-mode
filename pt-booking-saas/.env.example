# ------------------------------------------------------------------------------
# Supabase (PostgreSQL) 연결 문자열
# Supabase 대시보드 → Project Settings → Database → Connection string 에서 확인
# [project-ref], [YOUR-PASSWORD], 리전(aws-0-ap-northeast-2 등)은 본인 값으로 교체하세요.
# ------------------------------------------------------------------------------

# 앱 런타임에서 쓰는 커넥션 (Connection Pooling / PgBouncer, 6543 포트)
# 서버리스/엣지 환경에서 커넥션 폭주를 막기 위해 pooler 를 사용합니다.
DATABASE_URL="postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Prisma Migrate / introspection 이 쓰는 직접 연결 (Direct connection, 5432 포트)
# 마이그레이션은 pooler 를 통하면 안 되므로 반드시 direct 연결을 사용합니다.
DIRECT_URL="postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-ap-northeast-2.pooler.supabase.com:5432/postgres"
